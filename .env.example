# =============================================================================
# ArremateAI Userprofile — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# Variáveis marcadas como OBRIGATÓRIO não possuem valor padrão.
# =============================================================================

# === Servidor ===
SERVER_PORT=8085

# === Banco de Dados ===
DB_HOST=localhost
DB_PORT=5433
DB_NAME=arremateai
DB_USERNAME=arremateai
DB_PASSWORD=                # OBRIGATÓRIO — senha do banco de dados (sem valor padrão por segurança)

# === Upload de Arquivos ===
UPLOAD_MAX_FILE_SIZE=5MB
UPLOAD_MAX_REQUEST_SIZE=5MB

# === Armazenamento de Avatar ===
AVATAR_STORAGE_PATH=./uploads/avatars
USERPROFILE_BASE_URL=

# === Comunicação entre Microsserviços ===
INTERNAL_API_KEY=
GATEWAY_SHARED_SECRET=seu_secret_aqui    # OBRIGATÓRIO — segredo compartilhado com o Gateway para validação de requisições internas
